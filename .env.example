# ─────────────────────────────────────────────────────────────────────────────
# linkr-bot — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────
BOT_TOKEN=12345678:ABC-DEF1234ghIkl-zyx57W2P0s

# ── Telegram Bot API ──────────────────────────────────────────────────────────
BOT_API_URL=https://api.telegram.org

# How many simultaneous updates to process
CONCURRENT_UPDATES=30

# ── GoFile ────────────────────────────────────────────────────────────────────
# Optional: Get your token from https://gofile.io/myAccount
# Without token: uploads work but return page links (not direct links)
# With token: returns direct download links
# GOFILE_TOKEN=

# ── Limits ────────────────────────────────────────────────────────────────────
MAX_FILE_SIZE=50          # in MB

# ── Defaults ──────────────────────────────────────────────────────────────────
DEFAULT_LANGUAGE=en       # en | ar

# ── Access control ────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs. Leave empty to allow everyone.
WHITELIST=
# Bot admins (can use /stats, /broadcast)
ADMINS=

# ── Misc ──────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
TEMP_DIR=/tmp/linkr-bot
DB_PATH=linkr_bot.db